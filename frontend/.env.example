# Frontend Environment Variables - Example
# Copy as .env.local for local development
# Set in Vercel Dashboard for production

# Backend API URL
# Local development
VITE_API_URL=http://localhost:3000

# Production (Vercel)
# VITE_API_URL=https://your-api.railway.app
#
# After deploying to Railway/Render, update this URL
# Then redeploy frontend in Vercel
