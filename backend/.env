# Database Configuration
DATABASE_URL="sqlserver://localhost:1433;database=flight_booking;user=sa;password=duonghieu@3004;encrypt=true;trustServerCertificate=true"

# HTML Crawler Job Configuration
CRAWL_JOB_ENABLED=true
CRAWL_JOB_SCHEDULE=0 */8 * * *
CRAWL_SOURCE_URL=https://r.jina.ai/http://www.airportia.com/vietnam/noi-bai-international-airport/departures/
CRAWL_SOURCE_MODE=markdown
CRAWL_TIMEOUT_MS=15000
CRAWL_ORIGIN_CODE=HAN
CRAWL_TARGET_DATE=
CRAWL_DEFAULT_DURATION_MINUTES=120
CRAWL_FALLBACK_PRICE=1200000
EXPIRED_FLIGHT_CLEANUP_ENABLED=true
EXPIRED_FLIGHT_CLEANUP_SCHEDULE=15 */8 * * *

# Override selectors as JSON when target HTML structure differs
# Example:
# CRAWL_SELECTOR_JSON={"item":".flight-row","flightNumber":".code","originCode":".from .iata","destinationCode":".to .iata","departureTime":".dep","arrivalTime":".arr","basePrice":".price"}
CRAWL_SELECTOR_JSON=
# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-token-secret-change-this-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Session Configuration
SESSION_TIMEOUT=30

# MoMo Payment Gateway (Sandbox)
MOMO_PARTNER_CODE=your-partner-code
MOMO_ACCESS_KEY=your-access-key
MOMO_SECRET_KEY=your-secret-key
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_REDIRECT_URL=http://localhost:5173/payment/callback
MOMO_IPN_URL=http://localhost:3000/api/payments/ipn
MOMO_REQUEST_TYPE=captureWallet

# Frontend URL
FRONTEND_URL=http://localhost:5173
CORS_ALLOW_ALL=true

# Booking Configuration
BOOKING_TIMEOUT_MINUTES=15
